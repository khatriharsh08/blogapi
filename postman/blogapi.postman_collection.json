{
  "info": {
    "name": "Blog API - Laravel",
    "description": "Postman collection to test the Blog API (register, login, posts).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{regEmail}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirmation\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api", "register"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// generate unique email and password for the run",
              "pm.variables.set('regEmail', 'user' + Date.now() + '@example.com');",
              "pm.variables.set('password', 'Password123!');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "if (json.email) { pm.environment.set('regEmail', json.email); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{regEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Has token', function () { pm.expect(json.token).to.exist; });",
              "if (json.token) { pm.environment.set('token', json.token); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api", "posts"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "// Expect an array response (public endpoint)",
              "var json = pm.response.json();",
              "pm.test('Response is array', function () { pm.expect(json).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Post from Postman {{timestamp}}\",\n  \"body\": \"Automated post body\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api", "posts"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set('timestamp', Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.test('Response has id', function () { pm.expect(json.id || json.data?.id).to.exist; });",
              "// set postId for follow-up requests",
              "var id = json.id || (json.data && json.data.id);",
              "if (id) { pm.environment.set('postId', id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Post by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Has id', function () { pm.expect(json.id || json.data?.id).to.exist; });"
            ]
          }
        }
      ]
    }
  ]
}
